# Server
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Session (change this in production!)
SESSION_SECRET=skyloure-secret-key-change-in-production

# Google OAuth (optional — for "Sign in with Google")
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# SMTP / Email (optional — order confirmations; silently skipped when unset)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@skyloure.com
